{
  "name": "zenth",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "description": "Execution-first mobile productivity system for ADHD users",
  "scripts": {
    "dev:mobile": "pnpm --filter mobile exec expo start",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec -- rm -rf node_modules && rm -rf node_modules"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "next": "16.2.10"
  }
}
